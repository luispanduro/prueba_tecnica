# ==============================================
# Variables de entorno - User Management System
# ==============================================
# Copiar este archivo como .env y ajustar valores según necesidad.
# NUNCA commitear el archivo .env con secretos reales.

# --- PostgreSQL ---
POSTGRES_USER=admin
POSTGRES_PASSWORD=admin123
POSTGRES_DB=user_management

# --- MongoDB ---
MONGO_USER=admin
MONGO_PASSWORD=admin123
MONGODB_URI=mongodb://admin:admin123@mongodb:27017/audit?authSource=admin

# --- RabbitMQ ---
RABBITMQ_USER=guest
RABBITMQ_PASSWORD=guest
RABBITMQ_URL=amqp://guest:guest@rabbitmq:5672

# --- Redis ---
REDIS_URL=redis://redis:6379

# --- Qdrant ---
QDRANT_URL=http://qdrant:6333

# --- JWT ---
JWT_SECRET=local-development-secret-change-in-production
JWT_EXPIRATION=3600

# --- Service URLs (comunicación inter-servicio) ---
ROLE_SERVICE_URL=http://role-service:3003
USER_SERVICE_URL=http://user-service:3002
AUTH_SERVICE_URL=http://auth-service:3001

# --- Admin Seed (datos iniciales) ---
ADMIN_USER_ID=a0000000-0000-0000-0000-000000000001
ADMIN_USERNAME=admin
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=admin123
ADMIN_FIRST_NAME=System
ADMIN_LAST_NAME=Administrator

# --- OpenAI (LLM Provider) ---
# Requerido para el AI Service. Obtener en https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-api-key-here
OPENAI_MODEL=gpt-3.5-turbo
OPENAI_EMBEDDING_MODEL=text-embedding-ada-002
AI_MAX_TOKENS=1024
AI_TEMPERATURE=0.3

# --- Qdrant (AI Service) ---
QDRANT_COLLECTION=system_knowledge
