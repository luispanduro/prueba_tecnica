{
  "name": "user-management-microservices",
  "version": "1.0.0",
  "private": true,
  "description": "Sistema de gestión de usuarios basado en microservicios - Prueba técnica Senior Full-Stack Engineer (AI)",
  "workspaces": [
    "services/*",
    "shared",
    "frontend"
  ],
  "scripts": {
    "lint": "eslint . --ext .ts,.tsx",
    "lint:fix": "eslint . --ext .ts,.tsx --fix",
    "format": "prettier --write \"**/*.{ts,tsx,json,md}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,json,md}\"",
    "seed": "ts-node scripts/seed.ts",
    "test:all": "npm run test:backend && npm run test:frontend",
    "test:backend": "npm run test:shared && npm run test:auth && npm run test:user && npm run test:role && npm run test:audit && npm run test:ai",
    "test:shared": "cd shared && npx jest --passWithNoTests",
    "test:auth": "cd services/auth-service && npx jest --passWithNoTests",
    "test:user": "cd services/user-service && npx jest --passWithNoTests",
    "test:role": "cd services/role-service && npx jest --passWithNoTests",
    "test:audit": "cd services/audit-service && npx jest --passWithNoTests",
    "test:ai": "cd services/ai-service && npx jest --passWithNoTests",
    "test:frontend": "cd frontend && npx vitest run --pool=forks",
    "test:coverage": "npm run test:coverage:backend && npm run test:coverage:frontend",
    "test:coverage:backend": "npm run test:cov:shared && npm run test:cov:auth && npm run test:cov:user && npm run test:cov:role && npm run test:cov:audit && npm run test:cov:ai",
    "test:cov:shared": "cd shared && npx jest --coverage --passWithNoTests",
    "test:cov:auth": "cd services/auth-service && npx jest --coverage --passWithNoTests",
    "test:cov:user": "cd services/user-service && npx jest --coverage --passWithNoTests",
    "test:cov:role": "cd services/role-service && npx jest --coverage --passWithNoTests",
    "test:cov:audit": "cd services/audit-service && npx jest --coverage --passWithNoTests",
    "test:cov:ai": "cd services/ai-service && npx jest --coverage --passWithNoTests",
    "test:coverage:frontend": "cd frontend && npx vitest run --pool=forks --coverage"
  },
  "devDependencies": {
    "bcrypt": "^5.1.1",
    "dotenv": "^16.3.1",
    "pg": "^8.11.3",
    "ts-node": "^10.9.1",
    "typescript": "^5.1.3",
    "@types/bcrypt": "^5.0.2",
    "@types/pg": "^8.10.9"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "license": "UNLICENSED"
}
